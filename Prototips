# klase faila analīzei:
# tā izgūst informāciju par failu, nepieciešamo zināšanu bāzei analīzes veikšanai
# sākumā, tiek noteikts faila tips pēc tā paplašinajuma un tad, atkarīgi no faila tipa, tas saturs tiek analizēts.
# Teksta failiem pārbauda fontu, fonta izmēru, akcentu esamību un alternatīvus tekstus attēliem.
# Atseviškiem attēliem noteic vai ir pievienots aizstājejteksts.
# Atgriež saraksts par informāciju par izvēlēto analīzei faila saturu.
class faila_analize():
    # metode, kas izgūst faila tipu pēc tā paplašinājuma:
    def faila_info_izgusana(self, ext):
        # vārdnica ar pieejamiem apstrādei failu paplašinājumiem un šo paplašinājumu failu tipiem:
        ext_dict = {
            "text": ["docx", "pdf", "pptx"],
            "video": ["mp4", "mkv"],
            "photo": ["png", "jpg"]
        }

        # secīgi iziet šo vārdnīcu, salīdzinot saņemto paplašinājumu ar pieejamiem, lai iegūtu faila tipu
        # ja atrod šo paplašinājumu, tad atgriež attiecīgo faila tipu, citādi atgriež None, kas turpmāk norādīs uz faila nepieejamību apstrādei
        for x, y in ext_dict.items():
            if ext in y:
                return x

        return None

    # metode informācijas par failu izgūsanai:
    def teksta_faila_satura_parbaude(self, path, ext, kat):
        # saraksts, kurā glabasies analīzes laikā iegūta informācija, kur:
        # rezult = [vai ir korekts fonts teksta failā; vai ir korekts fonta izmērs teksta failā, vai ir akcenti teksta failā, vai teksta failā ir aizstājejteksti attēliem, vai attēlu failiem ir aizstājejteksti]
        # pēc noklusejuma visas vertības ir None, jo pēc tam pēc analīzes veikšanas, pēc tā, kuras vertības palika None būs iespēja saprast parliecināties, ka pārbaudīts bija korekts faila tips (jo cita faila tipa pārbaudes mainīgie paliks None)
        rezult = [None, None, None, None, None] 

        # metode, kas palīdzes izgūt no docx tipa failiem fonta izmēru, ja tas ir uzlikts pēc noklusējuma:
        def noklus_fonta_izm(file):
            # mēģina piekļut informācijai par noklusējuma fontu ar try, lai, ja fonts nav pēc noklusējuma, nekas nesabrūktu:
            try:
                # izgūva un saglaba informāciju par faila stilu:
                stils = file.styles.element

                # meklē vietu, kur stila XML tiek glabāta informācija par noklusējuma stila fonta izmēru:
                izm = stils.xpath('//w:docDefaults//w:sz')

                # ja kāda vērtība tiek glabāta, tad tiek izgūsts pirmais tas elements, kas glabj tieši fonta izmēru:
                if izm:
                    noklus_izm = izm[0].get('{http://schemas.openxmlformats.org/wordprocessingml/2006/main}val')

                    # ja vertība tur ir, tad atgriež šo vērtību dalītu ar divi, jo XML-ā ta vērtība ir glabāta puspunktos:
                    if noklus_izm:
                        return (int(noklus_izm)/2)
    
            # ja meklēšanas laikā noteik kāda kļūda, tad atgriež None, kā arī atgriež to pašu, ja nekas netiks atrasts (ja fonts failā ir ne pec noklusējuma):
            except Exception as e:
                return None
                
            return None
    
        # zemāk notiek faila apstrāde atkarīgi no tā paplašinajuma un tiek aizpildīts rezult saraksts:
        # 1. docx paplašinajuma failu apstrāde:
        if ext == "docx":
            # atvēr failu apstrādes veikšanai:
            fails = Document(path)

            # ja kategorijās ir "Izpratnes un mācīšanās speciālās vajadzības" kategorija, 
            # tad pārbauda faila fontu, fonta izmēru un akcentus:
            if "Izpratnes un mācīšanās speciālās vajadzības" in kat:
                # noteic vai failā ir noklusējuma fonta izmērs, būs nepieciešams nedaudz zemāk:
                noklus = noklus_fonta_izm(fails)

                # mainīgie satura aprakstam:
                # fonts_ir_arial - boolean vai fonts failā ir Arial
                # izmers_ir_korekts - boolean vai fonta izmērs failā ir vismaz 18 pt
                # akcenti - boolean vai failā ir izmantoti fonta akcenti (bold, italic, underline)
                fonts_ir_arial = True
                izmers_ir_korekts = True
                akcenti = False

                # pārbauda katru faila paragrafu:
                for p in fails.paragraphs:
                    # pārbauda katra paragrafa katru run-u
                    # (run - ir atseviška formatējuma saturs paragrafā, piemēram, 
                    # ja paragrafa ir teikums no diviem vārdiem, kur viens no vārdiem ir bold tekstā un otrs nav,
                    # tad šī paragrafā ir divi run-i jo ir divi atšķirīgie formātejumi) 
                    for run in p.runs:
                        # ingorē tukšus fragmentus, noņemot atstarpes un pārbaudot iegūto saturu:
                        if run.text.strip() == "":
                            continue
                        
                        # pārbaudā fonta izmēru:
                        # sākumā izmērs ir nezināms:
                        size = None

                        # pārbauda run līmeņa fonta izmēru, ja tas ir, tad piešķir tā vertību mainīgam size:
                        if run.font.size:
                            size = run.font.size.pt

                        # ja run-ā izmēra nav, tad pārbauda visa paragrafa stilu ar to izmēru:
                        elif p.style.font.size:
                            size = p.style.font.size.pt

                        # ja arī paragrafā nav noradīts fonta izmērs, tad tiek pieņemts, ka tas dokumentā ir pēc noklusējuma un tā vertība un tiek piešķirta size mainīgam:
                        elif noklus:
                            size = noklus

                        # failā izdevas atrast fonta izmēru:
                        if size is not None:
                            # pārbauda, vai tas ir atbilstošs, un ja tas ir mazāks par 18, tad mainīgais izmers_ir_korekts tiek mainīts uz False:
                            if size < 18:
                                izmers_ir_korekts = False
                            
                        # pārbauda fontu failā:
                        # sākumā pārbauda fontu run-ā:
                        fonts = run.font.name

                        # ja run-ā fonts nav noradīts, tad pārbauda to paragrafā:
                        if fonts is None:
                            fonts = p.style.font.name

                        # ja paragrafā arī nav noradīts fonts, tad paņem to no noklusējuma stila:
                        if fonts is None:
                            fonts = fails.styles["Normal"].font.name

                        # tad pārbauda vai fons ir atbistošs, un ja tas nav Arial, tad piešķir mainīgam fonts_ir_arial vertību False:
                        if fonts != "Arial":
                            fonts_ir_arial = False

                        # pārbauda akcentus failā:
                        # run līmenī pārbauda vai tajos ir kaut viens no bold/italc/underline akcentiem, ja ir, tad piesķir mainīgam akcenti true vertību:
                        if run.bold or run.italic or run.underline:
                            akcenti = True
                            
                # veiktas analīzes rezultātus pieraksta sarakstā rezult:
                rezult[0] = fonts_ir_arial
                rezult[1] = izmers_ir_korekts
                rezult[2] = akcenti
            
            # ja kategorijās ir "Sensorā speciālās vajadzības" kategorija, 
            # tad pārbauda aizstājejtekstus visiem attēliem failā
            if "Sensorā speciālās vajadzības" in kat:
                # mainīgas, kas glabj informāciju par to, vai visiem attēliem ir aizstājejteksts:
                visi_ok = True

                # iet cauri visiem faila attēliem:
                for att in fails.inline_shapes:
                    # katram attēlam meklē tas XML-ā sadaļu, kas glabj attēla īpašības:
                    apr = att._inline.xpath('.//wp:docPr')

                    # ja attēla īpašību apraksts eksistē, tad pārbauda tas daļu, kas glabj aizstājejtekstu:
                    if apr:
                        teksts = apr[0].get("descr") 

                        # ja aizstājejteksta nav, tad maina mainīga visi_ok vertību uz False:
                        if teksts is None or teksts.strip() == "":
                            visi_ok = False     
        
                # pievieno rezult sarakstam attēlu analīzes rezultātus:
                rezult[3] = visi_ok

        # 2. pptx paplašinajuma failu apstrāde:
        elif ext == "pptx":
            # atvēr failu apstrādes veikšanai:
            prs = Presentation(path)

            # ja kategorijās ir "Izpratnes un mācīšanās speciālās vajadzības" kategorija, 
            # tad pārbauda faila fontu, fonta izmēru un akcentus:
            if "Izpratnes un mācīšanās speciālās vajadzības" in kat:

                # mainīgie satura aprakstam:
                # fonts_ir_arial - boolean vai fonts failā ir Arial
                # izmers_ir_korekts - boolean vai fonta izmērs failā ir vismaz 18 pt
                # akcenti - boolean vai failā ir izmantoti fonta akcenti (bold, italic, underline)
                fonts_ir_arial = True
                izmers_ir_korekts = True
                akcenti = False

                # pārbauda katru faila slaidu:
                for slide in prs.slides:
                    # pārbauda katra slaida katru pieejamo objektu:
                    for shape in slide.shapes:
                        # pārbauda, vai objektam ir teksta lauks:
                        if shape.has_text_frame:
                            # ja teksts ir, tad pārbauda visas teksta rindkopas:
                            for p in shape.text_frame.paragraphs:
                                # katrā rindkopā pārbauda visus run-us:
                                for run in p.runs:
                                    # 1. pārbauda fonta tipu, ja nav atbilstošs, tad maina fonts_ir_arial mainīga vertību uz False:
                                    if run.font.name != "Arial":
                                        fonts_ir_arial = False

                                    # 2. pārbauda fonta izmēru, ja tas ir norādīts, bet nav atbilstošs, tad maina izmers_ir_korekts mainīga vertību uz False:
                                    if run.font.size:
                                        # dalīšana uz 12700, jo python-pptx glabā fonta izmēru angļu metrikas vienības un tos ir jākonvertē pt vertības:
                                        if (run.font.size / 12700) < 18:
                                            izmers_ir_korekts = False

                                    # 3. pārbauda fonta akcentu esamību, ja tāds tiek atrasts, tad maina akcenti mainīga vertību uz True:
                                    if run.font.bold or run.font.italic or run.font.underline:
                                        akcenti = True

                # veiktas analīzes rezultātus pieraksta sarakstā rezult:
                rezult[0] = fonts_ir_arial
                rezult[1] = izmers_ir_korekts
                rezult[2] = akcenti

            # ja kategorijās ir "Sensorā speciālās vajadzības" kategorija, 
            # tad pārbauda aizstājejtekstus visiem attēliem failā   
            if "Sensorā speciālās vajadzības" in kat:
                # mainīgas, kas glabj informāciju par to, vai visiem attēliem ir aizstājejteksts:
                visi_ok = True
                
                # pārbauda katru faila slaidu:
                for slide in prs.slides:
                    # pārbauda katra slaida katru pieejamo objektu:
                    for shape in slide.shapes:
                        # pārbauda vai tekošais objekt ir attēls vai nē:
                        if hasattr(shape, "image"):
                            # ja ir attēls, tad no attēla XML struktūras izgūst informāciju par attēlu:
                            apr = shape._element.xpath('.//p:cNvPr')

                            # ja informācija par attēlu iz pieejama, tad no tas izgūst aizstājejteksta esamību, 
                            # ja tāda nav, tad maina mainīga visi_ok vērtību uz False:
                            if apr:
                                if apr[0].get("descr") is None:
                                    visi_ok = False

                # pievieno rezult sarakstam attēlu analīzes rezultātus:
                rezult[3] = visi_ok           

        # 2. pdf paplašinajuma failu apstrāde:
        elif ext == "pdf":
            # atvēr failu apstrādes veikšanai:
            pdf = pymupdf.open(path)

            # ja kategorijās ir "Izpratnes un mācīšanās speciālās vajadzības" kategorija, 
            # tad pārbauda faila fontu, fonta izmēru un akcentus:
            if "Izpratnes un mācīšanās speciālās vajadzības" in kat:

                # mainīgie satura aprakstam:
                # fonts_ir_arial - boolean vai fonts failā ir Arial
                # izmers_ir_korekts - boolean vai fonta izmērs failā ir vismaz 18 pt
                # akcenti - boolean vai failā ir izmantoti fonta akcenti (bold, italic, underline)
                fonts_ir_arial = True
                izmers_ir_korekts = True
                akcenti = False

                # pārbauda katru faila lapaspusi:
                for page in pdf:   
                    # teksta izgūšana no pdf faila secīgi izjeot visas struktūras (bloks - rinda - teksta fragments):
                    txt_dict = page.get_text("dict")
                    for block in txt_dict["blocks"]:
                        for line in block.get("lines", []):
                            for span in line.get("spans", []):
                                # fonta pārbaude, ja nav Arial, tad maina mainiga fonts_ir_arial vērtību uz false:
                                if "Arial" not in span["font"]:
                                    fonts_ir_arial = False
      
                                # fonta izmēra pārbaude, ja ir < 18 pt, tad maina mainiga izmers_ir_korekts vērtību uz False:
                                if span["size"] < 18:
                                    izmers_ir_korekts = False

                                # akcentu pārbaude, ja kāds akcents ir atrasts, tad maina mainiga akcenti vērtību uz True:
                                if "Bold" in span["font"] or "Italic" in span["font"]:
                                    akcenti = True

                # veiktas analīzes rezultātus pieraksta sarakstā rezult:
                rezult[0] = fonts_ir_arial
                rezult[1] = izmers_ir_korekts
                rezult[2] = akcenti

            # ja kategorijās ir "Sensorā speciālās vajadzības" kategorija, 
            # tad pārbauda aizstājejtekstus visiem attēliem failā   
            if "Sensorā speciālās vajadzības" in kat:
                # mainīgas, kas glabj informāciju par to, vai visiem attēliem ir aizstājejteksts:
                visi_ok = True

                # pārbauda katru faila lapaspusi:
                for page in pdf: 

                    # iegūst visus lapa attēlus sarakstā:
                    atteli = page.get_images(full = True)

                    # iet cauri katram attēlam:
                    for attels in atteli:
                        # katra attēla unikāla identifikātora iegūšana:
                        id = attels[0]

                        # mēgina iegūst pilno attēla aprakstu pēc id:
                        try:
                            img = pdf.xref_object(id)

                            # pārbauda aizstājejteksta esamību, ja nav tad maina visi_ok mainīga vertību uz False:
                            if "/Alt" not in img:
                                visi_ok = False

                        # ja ir kāda kļūda attēla apstrādē arī noteic, ka teksta attēlam nav:
                        except:
                            visi_ok = False

                # pievieno rezult sarakstam attēlu analīzes rezultātus:
                rezult[3] = visi_ok

        # atgriež faila pārbaudes rezultātu sarakstu:
        return rezult     

    # metode attēlu failu pārbaudei:
    def attelu_faila_satura_parbaude(self, path, ext):
        # saraksts, kurā glabasies analīzes laikā iegūta informācija, kur:
        # rezult = [vai ir korekts fonts teksta failā; vai ir korekts fonta izmērs teksta failā, vai ir akcenti teksta failā, vai teksta failā ir aizstājejteksti attēliem, vai attēlu failiem ir aizstājejteksti]
        # pēc noklusejuma visas vertības ir None, jo pēc tam pēc analīzes veikšanas, pēc tā, kuras vertības palika None būs iespēja saprast parliecināties, ka pārbaudīts bija korekts faila tips (jo cita faila tipa pārbaudes mainīgie paliks None)
        rezult = [None, None, None, None, None] 

        # ja attēla paplašinājums ir jpg:
        if ext == "jpg":
            # atvēr attēlu apstrādes veikšanai:
            img = Image.open(path)

            # noteic datus par attēlu:
            vardn = img._getexif()

            # sākumā pieņemam, ka apraksta attēlam nav:
            ir = False

            # ja dati par attēlu eksistē, tad iziet cauri visiem tas ierakstiem, meklējot attēla aizstajejteksta sadaļu
            # ja tāda sadaļa tiek atrasta, tad maina mainīga "ir" vertību uz True: 
            if vardn:
                for tag in vardn.items():
                    if TAGS.get(tag) == "ImageDescription":
                        ir = True

            # pievieno rezult sarakstam attēla analīzes rezultātus:
            rezult[4] = ir
       
        # atgriež faila pārbaudes rezultātu sarakstu:
        return rezult 

