# Izmantotas bibliotēkas:
# customtkinter: lietotāja saskarnes veidošanai (piemēram, logiem, pogām)
# filedialog (no tkinter): failu izvēles loga importēšana, lai būtu iespēja izvēlēties failu no datorā esošajiem failiem
# Document (no python-docx): Document klase no python-docx bibliotēkas, lai apstrādātu .docx tipa failus
# Presentation (no python-pptx): Presentation klase no python-pptx bibliotēkas, lai apstrādātu .pptx tipa failus
# pymupdf: bibliotēka, kas nepieciešama .pdf tipa failu apstrādei
# Image (no PIL): bibliotēka, kas nepieciešama attēlu apstrādei
# TAGS (no PIL.ExifTags): vārdnīca, kas palīdz pārvērst kodus nosaukumos, lai atrastu sadaļu attēla datos pēc nosaukuma
import customtkinter
from tkinter import filedialog
from docx import Document
from pptx import Presentation
import pymupdf
from PIL import Image
from PIL.ExifTags import TAGS

# prototipa logu fona tēmas uzstādīšana uz tumšo režīmu:
customtkinter.set_appearance_mode("dark")

# klase, kas ar customtkinter bibliotēku izveido pamata logu, kurā tiks pārslēgtas prototipa darbības lapas:
class prototips(customtkinter.CTk):
    def __init__(self):
        super().__init__()

        # loga nosaukuma definēšana:
        self.title("Prototips")

        # loga pamata izmēru definēšana uz platumu = 1000 un augstumu = 500:
        self.geometry("1000x500")

        # grid konfigurācija, kas nepieciešama, lai loga saturs izplestos kopā ar loga izmēra manuālo mainīšanu:
        # kontrole, kā lapas tiks izplestas pa pamata logu horizontāli:
        self.grid_columnconfigure(0, weight=1)

        # kontrole, kā lapas tiks izplestas pa pamata logu vertikāli:
        self.grid_rowconfigure(0, weight=1)

        # mainīgais, lai glabātu, kura lapa tagad tiek attēlota lietotājam, katra klase to maina patstāvīgi ar metodi "attelo":
        self.pasreiz = None

        # "attelo" metodes izsaukšana pirmās lapas attēlošanai lietotājam:
        self.attelo(firstPage)

    # metode lapas attēlošanai logā, 
    # argumenti: self - atsauce uz pašu objektu, page - klase, kura maina lapu, *args - visi nepieciešamie papildargumenti, nodotie lapai
    def attelo(self, page, *args):
        # pārbaude, vai šobrīd kaut kas ir attēlots logā:
        if self.pasreiz is not None:
            # ja kāda lapa tiek attēlota, tad izdzēš to no loga, lai lapas nepārklātos:
            self.pasreiz.destroy()

        # izveido jaunu lapas objektu un saglabā to mainīgā, kas glabā, kura lapa tagad tiek attēlota lietotājam:
        self.pasreiz = page(self, *args)

        # novieto šo lapu logā pirmajā rindā, pirmajā kolonnā ar izplešanu visos virzienos ("nsew"):
        self.pasreiz.grid(row = 0, column = 0, sticky = "nsew")

# pirmās lapas klase
# attēlo informāciju par pašu prototipu, tā lietošanas instrukciju un pogu faila izvēlei
# nodrošina faila izvēli analīzes veikšanai un ceļa līdz tam izgūšanu
class firstPage(customtkinter.CTkFrame):
    def __init__(self, parent):
        super().__init__(parent)
        
        # saglabā atsauci uz pamata (vecāka) logu, lai būtu iespēja pēc tam pārslēgt lapas un izmantot citas metodes:
        self.parent = parent

        # konfigurē lapai trīs kolonnas, kur instrukcijas sadaļai vienmēr tiks atvēlēti 75% vietas un pogai 25%:
        self.grid_columnconfigure(0, weight=3)
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(1, weight=1)

        # prototipa pilna nosaukuma objekta izveide un attēlošana lapā:
        self.nosaukums = customtkinter.CTkLabel(self, text = "Automatizēts risinājums studiju materiālu analīzei un pielāgošanas rekomendāciju sniegšanai", fg_color = "#4747C4", text_color = "#ffffff", font = ("Arial", 14), corner_radius = 10)
        self.nosaukums.grid(row = 0, column = 0, columnspan = 2, padx = 20, pady = (15, 20), sticky = "ew")
        
        # prototipa instrukcijas teksta definēšana, objekta izveide un attēlošana lapā:
        instr_text = """
Instrukcija:
1. Izvēlieties vienu failu analīzes veikšanai attiecībā uz tā pieejamību studējošajiem ar speciālām vajadzībām;
2. Izvēlieties vienu vai vairākas funkcionēšanas ierobežojumu kategorijas, attiecībā uz kurām tiks veikta materiāla analīze;
3. Uzsāciet analīzi;
4. Saņemiet analīzes rezultātus :)

Pieejamie failu paplašinājumi: 
1. Teksta materiāli: .pdf, .docx, .pptx
2. Video materiāli: .mp4, .mkv
3. Attēli: .png, .jpg
        """
        self.instr = customtkinter.CTkLabel(self, text = instr_text, fg_color = "#4747C4", text_color = "#ffffff", font = ("Arial", 14), corner_radius = 10, justify = "left", wraplength = 400)
        self.instr.grid(row = 1, column = 0, padx = (30, 30), pady = 20, sticky = "nw")

        # pogas "Izvēlēties failu" objekta izveide un attēlošana lapā:
        self.poga_izvele = customtkinter.CTkButton(self, text = "Izvēlēties failu", command = self.faila_izvele)
        self.poga_izvele.grid(row = 1, column = 1, padx = (10, 30), pady = 20, sticky = "n")
        
    # izmantojot filedialog, dod iespēju lietotājam izvēlēties tikai vienu failu analīzei,
    # tad pārbauda, vai faila tips ir pieejams analīzei un vai izvēlēto failu ir iespējams nolasīt:
    def faila_izvele(self):
        # atver faila izvēles logu ar iespēju izvēlēties tikai vienu failu un saglabā informāciju par izvēlēto failu mainīgā "file_full":
        file_full = filedialog.askopenfile()

        # pārbauda, vai fails ir izvēlēts (file_full nav None):
        if file_full is not None:

            # saglabā tikai ceļu līdz izvēlētajam failam virknē, tā izmantošanai tālāk:
            file = str(file_full.name)

            # nosaka faila paplašinājumu:
            # sākumā virkne tiek sadalīta pēc "/" simboliem, ar to izveidojot sarakstu ar mainīgiem, katrs no kuriem ir daļa no pilna ceļa.
            # tad, mainīgā "name_ext" tiek saglabāts pēdejais("[-1]") izveidotā saraksta mainīgais, jo tajā atrodas faila nosaukums un paplašinājums, un konvertē to virknē.
            name_ext = str(file.split("/")[-1])

            # izveidoto virkni "name_ext" sadala no labās puses pēc punkta tikai vienu reizi, 
            # ar to izgūstot teksta pilno nosaukumu "self.name" un paplašinājumu "self.ext"
            # tiek darīts no labās puses un tikai vienu reizi, lai nodrošinātu, ka pat ja faila nosaukumā ir punkti, pat tad faila paplašinājums un nosaukums tiks atdalīti korēkti
            self.name = str(name_ext.rsplit(".", 1)[0])
            self.ext = str(name_ext.rsplit(".", 1)[1])

            # mainīgais faila paplašinājuma pārbaudei:
            fails_ir_pieejams = False

            # vārdnica ar pieejamiem apstrādei failu paplašinājumiem un šo paplašinājumu failu tipiem:
            ext_dict = {
                "text": ["pdf", "pptx", "docx"],
                "video": ["mp4", "mkv"],
                "photo": ["png", "jpg"]
            }

            # secīgi iziet šo vārdnīcu, salīdzinot saņemto paplašinājumu ar pieejamiem, lai iegūtu faila tipu
            # ja tāds tips ir atbalstams, tad maina mainīgā faila paplašinājuma pārbaudei "fails_ir_pieejams" vertību uz True:
            for x, y in ext_dict.items():
                if self.ext in y:
                    fails_ir_pieejams = True

            # ja tāds tips ir nav atbalstams, tad attēlo lietotājam kļūdas paziņojuma logu:
            if fails_ir_pieejams == False:
                self.parent.attelo(fileErrorPage)
                return

            # mainīgais faila pieejamības pārbaudei:
            lasisana_ir_pieejama = True

            # faila pieejamības lasīšanai pārbaude atkarībā no tā paplašinājuma:
            if self.ext == "docx":
                try:
                    fails = Document(file)
                except:
                    lasisana_ir_pieejama = False
            
            elif self.ext == "pptx":
                try:
                    prs = Presentation(file)
                except:
                    lasisana_ir_pieejama = False
            
            elif self.ext == "pdf":
                try:
                    pdf = pymupdf.open(file)
                except:
                    lasisana_ir_pieejama = False
            
            elif self.ext == "jpg":
                try:
                    img = Image.open(file)
                except:
                    lasisana_ir_pieejama = False
            
            # ja fails nav pieejams, tad lietotājam attēlo kļūdas ziņojumu par to, pretējā gadījumā lietotājam attēlo nākošo lapu:
            if lasisana_ir_pieejama == False:
                self.parent.attelo(fileErrorPage)
            else:
                self.parent.attelo(thirdPage, file)

# kļūdas ziņojuma (otrā) lapa:
# tiek attēlota lietotājam, ja izvēlētais fails kāda iemēsla dēļ nav pieejams apstrādei un dod iespēju izvēlēties citu failu:        
class fileErrorPage(customtkinter.CTkFrame):
    def __init__(self, parent):
        super().__init__(parent)

        # saglaba atsauci uz pamata (vecāka) logu, lai būtu iespeja pēc tam pāslēgt lapas un izmantot citas metodes:
        self.parent = parent

        # konfigurē 0. kolonnas uzvedību mainot loga izmērus, lai teksti vienmēr paliktu viena un ta pati vietā:
        self.grid_columnconfigure(0, weight = 1)

        # lapas virsraksta "Kļūda!" teksta objekta izveide un attēlošana lietotājam:
        self.err = customtkinter.CTkLabel(self, text = "Kļūda!", fg_color="#4747C4", text_color="#ffffff", font = ("Arial", 14, "bold"), corner_radius=10, justify="center")      
        self.err.grid(row = 0, column = 0, pady = (50, 15))
        
        # kļūdas teksta objekta izveide un attēlošana lietotājam:
        error_rep = """
Diemžēl izvēlētais fails nav pieejams analīzes veikšanai 
(nekorekts tips vai nav pieejams lasīšanai).
Lūdzu, izvēlieties citu failu!
"""     
        self.error_rep = customtkinter.CTkLabel(self, text = error_rep, fg_color="#4747C4", text_color="#ffffff", font = ("Arial", 14), corner_radius=10, justify="center")
        self.error_rep.grid(row = 1, column = 0, pady = (0, 15))
        
        # pogas "Izvēlēties citu failu" objekta izveide un attēlošana lapā:
        self.poga_cits = customtkinter.CTkButton(self, text = "Izvēlēties citu failu", fg_color = "#80C973", text_color = "#000000", command = self.poga_cits)
        self.poga_cits.grid(row = 2, column = 0)
        
    # pogas "Izvēlēties citu failu" apstrādes funkcija, ja poga iz uzspiesta, tad lietotājs tiek atgriezts sākumā logā:
    def poga_cits(self):
        self.parent.attelo(firstPage)


# trešas lapas klase:
# attēlo lietotājam informāciju par izvēlēto failu, dod iespēju failu izmainīt, 
# kā arī izvēlēties funkcionēšanas ierobezojumu kategorijas analīzes pielāgošanai.
# kā argumentu saņem ceļu līdz izvēlētam failam "path":
class thirdPage(customtkinter.CTkFrame):
    def __init__(self, parent, path):
        super().__init__(parent)

        # saglaba atsauci uz pamata (vecāka) logu, lai būtu iespeja pēc tam pāslēgt lapas un izmantot citas metodes:
        self.parent = parent

        # saglaba ceļu līdz izvēlētam failam mainīgā "file" un "self.path":    
        self.path = path
        file = self.path

        # konfigurē lapai trīs kolonnas, kur uz instrukcijas sadaļu vienmēr tiks atvēlēts 75% vietas un uz pogu 25%:
        self.grid_columnconfigure(0, weight=3)
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(1, weight=1)

        # definē mainīgo logam kas tiks attēlots virs pamata loga, sākumā ir None:
        self.toplevel_window = None

        # izgūst faila paplašinājumu mainīgajā self.ext:
        name_ext = str(file.split("/")[-1])
        self.name = str(name_ext.rsplit(".", 1)[0])
        self.ext = str(name_ext.rsplit(".", 1)[1])

        # definē sarakstu, kurā glabāsies izvēlētas analīzei funkcionēšanas kategorijas:
        self.kategorijas = []

        # informācijas par izvēlēto failu rakstīšana, objekta izveide un attēlošana lietotājam:
        text_izv = "\n Informācija par izvēlēto failu: \n\n1. Faila nosaukums: " + self.name + "\n\n2. Faila paplašinājums: " + self.ext + "\n\n3. Izvēlētās funkcionēšanas ierobežojumu kategorijas: \n" + str(self.kategorijas) + "\n"
        self.inf_txt = customtkinter.CTkLabel(self, text = text_izv, fg_color="#4747C4", text_color="#ffffff", font = ("Arial", 14), corner_radius=10, justify="left")
        self.inf_txt.grid(row = 0, column = 0, padx = (30, 30), pady = 20, sticky = "nw")

        # pogas "Izvēlēties speciālās vajadzības kategoriju(-as)" objekta izveide un attēlošana lapā:
        self.poga_kategorijas = customtkinter.CTkButton(self, text="Izvēlēties speciālās vajadzības kategoriju(-as)", fg_color="#80C973", text_color="#000000", command=self.pogai_kategor)
        self.poga_kategorijas.grid(row = 0, column = 1, padx = (10, 30), pady = (20, 5), sticky = "n") 
        
        # pogas "Izvēlēties citu failu" objekta izveide un attēlošana lapā:
        self.poga_cits_f = customtkinter.CTkButton(self, text="Izvēlēties citu failu", fg_color="#C50707", text_color="#000000", command=self.pogai_cits_fails)
        self.poga_cits_f.grid(row = 0, column = 1, padx = (10, 30), pady = (100, 5), sticky = "n")

        # pogas "Uzsākt analīzi!" objekta izveide un attēlošana lapā:
        self.poga_analize = customtkinter.CTkButton(self, text="Uzsākt analīzi!", fg_color="#80C973", text_color="#000000", command=self.pogai_analize)
        self.poga_analize.grid(row = 2, column = 0, columnspan = 2, padx = 30, pady = (10, 10), sticky = "ew")    
    
    # metode pogas "Izvēlēties speciālās vajadzības kategoriju(-as)" apstrādei:
    # dod iespeju izvēlēties funkcionēšanas ierobezojumu kategorijas, atverot tam speciālo top līmeņa logu,
    # kā arī maina pogas tekstu uz "Izmainīt izvēlētās speciālās vajadzības kategoriju(-as)"
    def pogai_kategor(self):
        # maina pogas tekstu uz "Izmainīt izvēlētās speciālās vajadzības kategoriju(-as)":
        self.poga_kategorijas.configure(text="Izmainīt izvēlētās speciālās vajadzības kategoriju(-as)")

        # pārbauda, lai nekādi top līmeņa papildus logi nebūtu atverti, lai vairaki logi netiktu pārklati viens uz otra:
        if self.toplevel_window is None or not self.toplevel_window.winfo_exists():
            # ja nekādu citu top līmeņa logu nav, tad veido jaunu ar kategoriju izvēli:
            self.toplevel_window = topKatIzvele(self)
        else:
            # kad logs tik izveidots, fokusejas uz tā:
            self.toplevel_window.focus()

    # metode pogas "Izvēlēties citu failu" apstrādei:
    # pēc nospiešanas brīdina lietotāju ar jauno logu, kā ievadīta informācija būs pazaudēta 
    # un dod iespēju vai nu tomēr izmainīt izvēlēto failu, vai atgriezties atpakaļ pamata loga:
    def pogai_cits_fails(self):
        # pārbauda, lai nekādi top līmeņa papildus logi nebūtu atverti, lai vairaki logi netiktu pārklati viens uz otra:
        if self.toplevel_window is None or not self.toplevel_window.winfo_exists():
            # ja nekādu citu top līmeņa logu nav, tad veido jaunu ar bridinājumu:
            self.toplevel_window = bridinajums(self)
        else:
            # kad logs tik izveidots, fokusejas uz tā:
            self.toplevel_window.focus()

    # metode, nepieciešama lai atgrieztu izvēlētas kategorijas mainīga tipi un atjaunotu tos lietotāja lapā:
    def ret(self, tipi): 
        # izvēlēto tipu pieraksts mainīgā self.kategorijas:
        self.kategorijas = tipi

        # jauna teksta izveide:
        jauns_teksts = "\n Informācija par izvēlēto failu: \n\n1. Faila nosaukums: " + self.name + "\n\n2. Faila paplašinājums: " + self.ext + "\n\n3. Izvēlētās funkcionēšanas ierobežojumu kategorijas: \n" + str(tipi) + "\n"
        self.inf_txt.configure(text = jauns_teksts)
    
    # metode pogas "Uzsākt analīzi!" apstrādei:
    def pogai_analize(self):
        # pārbauda, lai kategorijas būtu izvēlētas, tikai tad mēģina uzsākt analīzi:
        if len(self.kategorijas) != 0:
            # tiek pildīts ar try lai apstrādatu iespējamas kļūdas, kāda iemesla dēļ nepaķertas pirmajas parbaudēs:
            try:
                # piešķiram mainīgiem vert, rek, atg faila analīzes rezultātus, nosūtot ceļu līdz failam, to paplašinājumu un izvēlētas kategorijas: 
                # vert - vērtējums, vai fails ir pielāgots, 
                # rek - individuālās rekomendācijas pēc faila anlīzes, 
                # atg - kopējas rekomendācijas jebkuram izvēlēta tipa faila saturam
                vert, rek, atg = baze(self.path, self.ext, self.kategorijas)

                # ja viss tiek veiksmīgi saņemts, tad attēlo lietotājam analīzes rezultātus:
                self.parent.attelo(analizeRezultats, self.name, self.ext, self.kategorijas, vert, rek, atg)

            # ja tiek paķerta kāda kļūda - attēlo informāciju par to lietotājam:
            except:
                self.parent.attelo(fileErrorPage)
        else: 
            # brīdinajuma par nevienu izvēlētu kategoriju teksta objekta izveide un attēlošana lietotājam:
            self.navKat = customtkinter.CTkLabel(self, text = "Nav izvēlētā neviena kategorija", text_color="#B62C2C", font = ("Arial", 14))
            self.navKat.grid(row = 1, column = 0, columnspan = 2, padx = 10, pady = (5, 0), sticky = "ew")     


# top līmeņa loga klase, kas brīdina lietotāju, ka izvēloties citu failu, ievadītas kategorijas tiks pazaudētas,
# kā arī dod iepseju vai nu izmainīt failu, vai atgriezties pamata logā:
class bridinajums(customtkinter.CTkToplevel):
    def __init__(self, parent, *args, **kwargs):
        super().__init__(parent, *args, **kwargs)
        
        # daļa, nepieciešama, lai atvērtais logs paliktu virs pamata loga:
        self.lift()
        self.attributes("-topmost", True)
        self.after(100, lambda: self.attributes("-topmost", False))

        # saglaba atsauci uz pamata (vecāka) logu, lai būtu iespeja pēc tam pāslēgt lapas un izmantot citas metodes:
        self.parent = parent

        # definē atverta loga nosaukumu, izmēru un izkārtojumu:
        self.title("Uzmanību!")
        self.geometry("600x500")
        self.grid_columnconfigure((0, 1), weight = 1)
        self.grid_rowconfigure((0, 1, 2, 3), weight = 1)

        # loga virsraksta "Uzmanību!" teksta objekta izveide un attēlošana lietotājam:
        self.uzm_txt = customtkinter.CTkLabel(self, text="Uzmanību!", fg_color="#B62C2C", text_color="#ffffff", font = ("Arial", 14, "bold"), corner_radius=10)
        self.uzm_txt.grid(row = 0, column = 0, columnspan = 2, pady = (20, 10))

        # loga paziņojuma teksta objekta izveide un attēlošana lietotājam:
        self.pazin_txt = customtkinter.CTkLabel(self, text="Izvēloties citu failu, visa iepriekš ievadīta informācija tiks izdzēsta.", fg_color="#4747C4", text_color="#ffffff", font = ("Arial", 14, "bold"), corner_radius=10)
        self.pazin_txt.grid(row = 1, column = 0, columnspan = 2, pady = 10)

        # loga jautājuma teksta objekta izveide un attēlošana lietotājam:
        self.jaut_txt = customtkinter.CTkLabel(self, text="Vai Jūs tiešām gribāt izvēlēties citu failu?", fg_color="#4747C4", text_color="#ffffff", font = ("Arial", 14, "bold"), corner_radius=10)
        self.jaut_txt.grid(row = 2, column = 0, columnspan = 2, pady = 10)

        # pogas "Izvēlēties jaunu failu" objekta izveide un attēlošana logā:
        self.button_apst = customtkinter.CTkButton(self, text="Izvēlēties jaunu failu", fg_color="#80C973", text_color="#000000", command=self.poga_ja)
        self.button_apst.grid(row=3, column=0, padx=(40, 20), pady = 20, sticky="e")

        # pogas "Atgriezties" objekta izveide un attēlošana logā:
        self.button_aizl = customtkinter.CTkButton(self, text="Atgriezties", fg_color="#80C973", text_color="#000000", command=self.poga_ne)
        self.button_aizl.grid(row=3, column=1, padx=(20, 40), pady = 20, sticky="w")

    # pogas "Izvēlēties jaunu failu" apstrādes metode:
    # ja poga iz uzspiesta, tad atgriež lietotaju uz sākuma logu, bet pašu top līmeņa logu dzēš:
    def poga_ja(self):
        self.parent.parent.attelo(firstPage)
        self.destroy()

