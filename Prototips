# funkcija, kas pārvalda analīzes procesu:
def baze(path, ext, kat):
    # objekts faila analīzes metozu izsaukšanai:
    parb = faila_analize()

    # objekts zināšanau bāzes izsaukšanai:
    zin = zinasanu_baze()

    # faila tipa izgušana pēc faila paplāšinājuma:
    tips = parb.faila_info_izgusana(ext)

    # ja tips nav atrasts, tad analīze tiek pārtraukta:
    if tips is None:
        return "Nezināms faila tips", [], ""

    # ja fails ir teksta materiāls, tad uzsāk teksta failu pārbaudes bloku:
    if tips == "text":
        rez = parb.teksta_faila_satura_parbaude(path, ext, kat)
     
    # ja fails ir attēla materiāls, tad uzsāk attēlu pārbaudes bloku:
    elif tips == "photo":
        rez = parb.attelu_faila_satura_parbaude(path, ext)

    # ja fails ir video materiāls, personalizēta pārbaude sobrīd netiek veikta:
    else:
        rez = [None, None, None, None, None]

    # nodod visus rezultātus zināšanu bāzei kriteriju pārbaudei: 
    return zin.zinasanu_baze(ext, tips, kat, rez)
    
